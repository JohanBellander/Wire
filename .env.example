# Copy to .env and fill in real values. .env is gitignored.

ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ---- LLM model selection -------------------------------------------------
# Provider, per-task Claude models, and the llama.cpp endpoint live here so
# they can be flipped from Coolify without editing /data/config.yaml.

# Required. Which backend handles every LLM call: `claude` (Anthropic only)
# or `llamacpp` (OpenAI-compatible local primary, Claude as fallback).
WIRE_LLM_PROVIDER=claude

# Required. Per-task Claude models. Used directly when provider=claude, and
# as the fallback path when provider=llamacpp.
WIRE_CLAUDE_DRAFTING_MODEL=claude-sonnet-4-6
WIRE_CLAUDE_TRIAGE_MODEL=claude-haiku-4-5
WIRE_CLAUDE_VOICE_PROFILE_MODEL=claude-haiku-4-5
WIRE_CLAUDE_DIGEST_MODEL=claude-haiku-4-5

# Required only when WIRE_LLM_PROVIDER=llamacpp. The OpenAI-compatible
# endpoint (llama.cpp server, vLLM, OpenRouter, ...). base_url MUST include
# the /v1 segment.
# WIRE_LLAMACPP_BASE_URL=https://llm.example.com/v1
# WIRE_LLAMACPP_MODEL=qwen3-coder-next
# WIRE_LLAMACPP_TIMEOUT_SECONDS=90
# WIRE_LLAMACPP_TEMPERATURE=0.5

# Required only when WIRE_LLM_PROVIDER=llamacpp. Bearer token for the
# OpenAI-compatible endpoint. Leave blank for unauth'd local servers.
LLM_API_KEY=

# Optional: log verbosity (DEBUG | INFO | WARNING | ERROR). Defaults to INFO.
# WIRE_LOG_LEVEL=INFO

# Optional: path to config.yaml inside the container. Defaults to /data/config.yaml.
# WIRE_CONFIG_PATH=/data/config.yaml

# Optional: set to 1 to allow startup without /data/config.yaml present (local dev only).
# WIRE_DEV=1
